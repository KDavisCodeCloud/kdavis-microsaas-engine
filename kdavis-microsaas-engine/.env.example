# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Supabase Management API (Phase 6b per-product provisioning — org-level
# personal access token from supabase.com/dashboard/account/tokens)
SUPABASE_ACCESS_TOKEN=sbp_...
SUPABASE_ORG_ID=your-org-id

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Resend
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=outreach@your-verified-sending-domain.com

# Stripe (this product's dedicated account)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# App
ALLOWED_ORIGINS=http://localhost:3000,https://your-product-domain.com
APP_ENV=development

# Marketing engine (n8n -> /marketing/research, /marketing/campaign, /marketing/apollo-list, /marketing/dm-sequences, /marketing/seo-content)
MARKETING_API_KEY=

# Apollo.io (mkt_o1_apollo_list_builder — skips gracefully with status=skipped if unset, does not crash)
APOLLO_API_KEY=

# Systeme.io (mkt_o3_email_sequence_loader — SYSTEME_API_KEY is required when that agent runs; SYSTEME_API_BASE_URL is optional, falls back to a built-in default)
SYSTEME_API_KEY=
SYSTEME_API_BASE_URL=

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000
