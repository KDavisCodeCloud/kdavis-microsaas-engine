# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Supabase Management API (Phase 6b per-product provisioning — org-level
# personal access token from supabase.com/dashboard/account/tokens)
SUPABASE_ACCESS_TOKEN=sbp_...
SUPABASE_ORG_ID=your-org-id

# GitHub (brief_generator pushes the brief/{slug} branch — a fine-grained
# PAT with Contents: Read and write on kdavis-microsaas-engine is enough.
# Without this set, git push falls back to ambient credentials, which
# only exist in an interactive session, not on the deployed Railway
# service — confirmed by a real "could not read Username" failure
# 2026-07-17 when this var wasn't set yet.)
GITHUB_TOKEN=github_pat_...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Resend
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=outreach@your-verified-sending-domain.com

# Stripe (this product's dedicated account)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Railway + Vercel (agents/factory/deploy.py — non-interactive CLI auth
# for the build/deploy pipeline. Without these, deploy.py assumes an
# already-logged-in interactive session, which the deployed mse-api
# service does not have — it now fails fast with a specific "RAILWAY_TOKEN
# is not set" / "VERCEL_TOKEN is not set" error instead of failing deep
# into a partial deploy. Get RAILWAY_TOKEN from railway.app account
# settings > Tokens; get VERCEL_TOKEN from vercel.com account settings >
# Tokens. Fixed 2026-07-20.)
RAILWAY_TOKEN=...
VERCEL_TOKEN=...

# App
ALLOWED_ORIGINS=http://localhost:3000,https://your-product-domain.com
APP_ENV=development

# Marketing engine (n8n -> /marketing/research, /marketing/campaign, /marketing/apollo-list, /marketing/dm-sequences, /marketing/seo-content)
MARKETING_API_KEY=

# Apollo.io (mkt_o1_apollo_list_builder — skips gracefully with status=skipped if unset, does not crash)
APOLLO_API_KEY=

# Systeme.io (mkt_o3_email_sequence_loader — SYSTEME_API_KEY is required when that agent runs; SYSTEME_API_BASE_URL is optional, falls back to a built-in default)
SYSTEME_API_KEY=
SYSTEME_API_BASE_URL=

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000
